# Daily Reminders Agent -- environment variables (example)
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# These OVERRIDE the defaults in config.py. Using a .env is preferred if this
# repo is ever public, so the topic/URL never get committed.
#
# Load it into your shell before running the script:
#     set -a; source .env; set +a
#     python3 send_reminder.py
#
# For cron, env vars are NOT auto-loaded -- source the file in the cron command:
#     0 9 * * * cd /path/to/daily-reminders-agent && set -a && . ./.env && set +a && /usr/bin/python3 send_reminder.py >> reminder.log 2>&1

# ntfy topic to publish to (subscribe to this exact name in the ntfy app).
# Make it long and unguessable -- it acts as your password.
NTFY_TOPIC="mavram-reminders-CHANGE-ME-9fk3qz"

# ntfy server. Leave as the public server unless you self-host.
NTFY_SERVER="https://ntfy.sh"

# Raw URL of reminders.txt inside your secret gist (no commit hash = always latest).
GIST_RAW_URL="https://gist.githubusercontent.com/USER/ID/raw/reminders.txt"
